SELECT DISTINCT ?cityName ?population ?coords ?countryName 
(str(?continentName) AS ?continent) 
(str(?langName) AS ?officialLanguage)
WHERE {
  ?city wdt:P31/wdt:P279* wd:Q515;
        wdt:P1082 ?population;
        wdt:P625 ?coords;
        wdt:P17 ?country;
        rdfs:label ?cityName.
  
  ?country rdfs:label ?countryName;
           wdt:P30 ?continentEntity.
  
  ?continentEntity rdfs:label ?continentName.

  OPTIONAL {
    ?country wdt:P37 ?langEntity.
    ?langEntity rdfs:label ?langName.
    FILTER (LANG(?langName) = "en")
  }

  FILTER (LANG(?cityName) = "en")
  FILTER (LANG(?countryName) = "en")
  FILTER (LANG(?continentName) = "en")
  FILTER (?population > 1000000)
}
